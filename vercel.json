{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  },
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  },
  "crons": [
    {
      "path": "/api/cron/refresh-prices",
      "schedule": "0 */6 * * *"
    }
  ],
  "functions": {
    "src/app/api/cron/refresh-prices/route.ts": {
      "maxDuration": 300
    }
  }
}