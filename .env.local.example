# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# ============================================================
# Brevo (newsletter signup + welcome email)
# Used by src/app/api/subscribe/route.ts and src/app/api/newsletter/route.ts
# ============================================================
# Master Brevo API key — likely shared across the network (SHE / GGHQ / PetPal)
# Get from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# PetPalHQ-specific list ID. Create a list in Brevo named "PetPalHQ Subscribers"
# then read its numeric ID from the list URL or dashboard.
BREVO_LIST_ID=

# PetPalHQ-specific welcome email template ID. Create a transactional template
# in Brevo named "PetPalHQ Welcome" then note its numeric ID.
BREVO_WELCOME_TEMPLATE_ID=

# ============================================================
# Amazon Associates / Creators API
# ============================================================
# These are usually shared across the network (one Amazon Associate account, many sites).
# For local dev you can leave blank — guides fall back to the existing creators-api.ts behavior.
AMAZON_ASSOCIATES_TAG=petpalhq08-20
AMAZON_CREATORS_API_CLIENT_SECRET=

# ============================================================
# Google Analytics (optional)
# ============================================================
NEXT_PUBLIC_GA_ID=

# ============================================================
# IndexNow (optional)
# Used by src/app/api/indexnow/route.ts to ping Bing/Yandex on guide updates
# ============================================================
INDEXNOW_KEY=
