# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.
#
# Variable names below match what the codebase actually reads via
# process.env.* — do not rename without updating consumers.

# ============================================================
# Brevo — newsletter signup + welcome email
# Used by src/app/api/subscribe/route.ts and src/app/api/newsletter/route.ts
# ============================================================
# Master Brevo API key — shared across the network (SHE / GGHQ / PetPal)
# Get from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# PetPalHQ-specific list ID. Create a list in Brevo named "PetPalHQ Subscribers"
# then read its numeric ID from the list URL or dashboard.
BREVO_LIST_ID=

# PetPalHQ-specific welcome email template ID. Create a transactional template
# in Brevo named "PetPalHQ Welcome" then note its numeric ID.
BREVO_WELCOME_TEMPLATE_ID=

# ============================================================
# Amazon Creators API + Associates affiliate tag
# Used by src/lib/amazon-api.ts (price refresh cron) and buildAmazonUrl helpers
# ============================================================
# OAuth client credentials. From: https://affiliate-program.amazon.com/ (Creators
# API access; usually shared across the network — same client for SHE / GGHQ / PetPal).
# Look up in 1Password: op://API Keys/Amazon Creators API - New Client/{username,credential}
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=

# Amazon Associates affiliate tag (the petpalhq-specific "track ID"). Default
# value below works for local dev; production reads the same env var.
AMAZON_AFFILIATE_TAG=petpalhq08-20

# ============================================================
# Google services
# ============================================================
# Public GA4 measurement ID. Used by src/components/GoogleAnalytics.tsx.
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google service account credentials — TWO patterns, both used in this project:
#
# (a) GOOGLE_APPLICATION_CREDENTIALS: file PATH to the SA JSON. Used locally
#     by scripts/google-index-submit.ts (Google Cloud SDK convention).
#     Local dev: point at a local SA JSON file, e.g.:
#       GOOGLE_APPLICATION_CREDENTIALS=/Users/you/.config/gcloud/petpal-sa.json
#     1Password: op read "op://API Keys/Google Search Console SA/credential" > /tmp/petpal-sa.json
GOOGLE_APPLICATION_CREDENTIALS=

# (b) GOOGLE_SERVICE_ACCOUNT_KEY: base64-encoded SA JSON. Used by
#     src/app/api/analytics/gsc/route.ts in serverless env (Vercel can't store
#     credential files; must inline as base64 env var).
#     Generate locally: cat sa.json | base64
GOOGLE_SERVICE_ACCOUNT_KEY=

# ============================================================
# Vercel Cron — auth secret for /api/cron/* endpoints
# Used by src/app/api/cron/refresh-prices/route.ts
# ============================================================
# Any random string — used to authenticate cron calls.
# Set the same value in Vercel project env (Settings → Environment Variables)
# AND pass via Authorization: Bearer header or ?secret= query param.
# Generate: openssl rand -hex 32
CRON_SECRET=

# ============================================================
# IndexNow — push to Bing/Yandex/Naver/Brave/etc. on guide updates
# Used by src/app/api/indexnow/route.ts and the post-deploy GH Actions workflow
# ============================================================
# Petpal-specific 32-char hex key. Must match public/97b4501830e1517ea48c01d86ff03a81.txt.
# Current value is committed to the repo workflow secret already; this is for
# local-script use if you need to ping IndexNow manually.
INDEXNOW_KEY=97b4501830e1517ea48c01d86ff03a81

# ============================================================
# Optional: Vercel deploy hook for liveness watchdog auto-recovery
# Used by .github/workflows/liveness-watchdog.yml (set as repo secret in GitHub)
# ============================================================
# Vercel dashboard → petpalhq-next → Settings → Git → Deploy Hooks → Create.
# Without it, watchdog files an issue on URL failures but cannot self-recover.
# This var is NOT used by the runtime app — it lives in GitHub repo secrets.
# VERCEL_DEPLOY_HOOK_URL=
